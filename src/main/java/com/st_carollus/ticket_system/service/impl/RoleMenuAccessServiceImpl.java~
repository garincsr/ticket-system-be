    public RoleMenuAccessResponse update(String id, RoleMenuAccessRequest request) {
        RoleMenuAccess roleMenuAccess = findEntityById(id);
        Menu menu = menuService.getEntityByMenuCode(request.getMenuCode());
        Role role = roleService.getEntityByRoleCode(request.getRoleCode());

        roleMenuAccess.setRole(role);
        roleMenuAccess.setMenu(menu);
        roleMenuAccess.setCanView(request.getCanView());
        roleMenuAccess.setCanCreate(request.getCanCreate());
        roleMenuAccess.setCanEdit(request.getCanEdit());
        roleMenuAccess.setCanDelete(request.getCanDelete());

        return toResponse(roleMenuAccessRepository.save(roleMenuAccess));
    }

    @Override
    public void delete(String id) {
        RoleMenuAccess roleMenuAccess = findEntityById(id);
        roleMenuAccessRepository.delete(roleMenuAccess);
    }

    private List<RoleMenuAccess> findEntityByRoleId(String id) {
        return roleMenuAccessRepository.findByRole_Id(id);
    }

    private RoleMenuAccess findEntityById(String id) {
        return roleMenuAccessRepository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException("RoleMenuAccess not found"));
    }

    private RoleMenuAccessResponse toResponse(RoleMenuAccess roleMenuAccess) {
        return RoleMenuAccessResponse.builder()
                .id(roleMenuAccess.getId())
                .roleCode(roleMenuAccess.getRole().getRoleCode())
                .menu(roleMenuAccess.getMenu())
                .canView(roleMenuAccess.getCanView())
                .canCreate(roleMenuAccess.getCanCreate())
                .canEdit(roleMenuAccess.getCanEdit())
                .canDelete(roleMenuAccess.getCanDelete())
                .build();
    }
}
